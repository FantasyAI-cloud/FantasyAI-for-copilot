{
  "name": "fantasyai-copilot",
  "displayName": "FantasyAI for Copilot",
  "description": "Use FantasyAI as a native Copilot Chat language model provider.",
  "version": "1.0.0",
  "publisher": "fantasyai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fantasyai/fantasyai-copilot.git"
  },
  "keywords": ["fantasyai", "copilot", "ai", "chat"],
  "engines": { "vscode": "^1.90.0" },
  "categories": ["AI", "Chat", "Other"],
  "icon": "icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      { "command": "fantasyAI.openChat",       "title": "FantasyAI: Open Chat" },
      { "command": "fantasyAI.setApiKey",      "title": "FantasyAI: Set API Key" },
      { "command": "fantasyAI.clearApiKey",    "title": "FantasyAI: Clear API Key" },
      { "command": "fantasyAI.pickModel",      "title": "FantasyAI: Pick Model" },
      { "command": "fantasyAI.refreshModels",  "title": "FantasyAI: Refresh Models" },
      { "command": "fantasyAI.testConnection", "title": "FantasyAI: Test Connection" }
    ],
    "configuration": {
      "title": "FantasyAI",
      "properties": {
        "fantasyAI.activeModel": {
          "type": "string",
          "default": "",
          "description": "Currently active FantasyAI model ID."
        },
        "fantasyAI.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "Sampling temperature (0–2)."
        },
        "fantasyAI.maxTokens": {
          "type": "number",
          "default": 8192,
          "minimum": 1,
          "description": "Maximum output tokens per response."
        },
        "fantasyAI.contextWindow": {
          "type": "number",
          "default": 128000,
          "minimum": 1024,
          "description": "Context window advertised to Copilot."
        },
        "fantasyAI.systemPrompt": {
          "type": "string",
          "default": "You are a helpful coding assistant inside VS Code."
        },
        "fantasyAI.requestTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 1000
        },
        "fantasyAI.modelRefreshIntervalMs": {
          "type": "number",
          "default": 300000,
          "minimum": 30000,
          "description": "How often (ms) to auto-refresh the model list. Minimum 30s."
        },
        "fantasyAI.detection.timeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 1000,
          "description": "Per-model probe timeout (ms) during capability detection."
        },
        "fantasyAI.detection.concurrency": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Parallel probes during capability detection. 0 = auto."
        }
      }
    },
    "languageModelChatProviders": [
      {
        "vendor": "fantasyai",
        "displayName": "FantasyAI"
      }
    ],
    "menus": {
      "commandPalette": [
        { "command": "fantasyAI.openChat" },
        { "command": "fantasyAI.setApiKey" },
        { "command": "fantasyAI.clearApiKey" },
        { "command": "fantasyAI.pickModel" },
        { "command": "fantasyAI.refreshModels" },
        { "command": "fantasyAI.testConnection" }
      ]
    }
  },
  "scripts": {
    "lint": "node --check extension.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  }
}
